# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# =============================================================================
# Application Secrets
# =============================================================================

# Flask secret key for session signing and CSRF protection
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-64-char-hex-secret-here

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL credentials
# Use strong passwords in production!
POSTGRES_USER=minerva
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_DB=minerva

# =============================================================================
# ODK Integration
# =============================================================================

# ODK credential encryption pepper — generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
ODK_CREDENTIAL_PEPPER=your-random-64-char-hex-secret-here

# =============================================================================
# Email / SMTP Configuration
# =============================================================================

# SMTP server for sending emails (forgot password, email verification)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@digitva.org
# Base URL for email links (no trailing slash)
# MAIL_BASE_URL=https://digitva.example.com
# Optional: disable outbound delivery (keeps queueing logic but skips sending)
# EMAIL_DELIVERY_ENABLED=true
# Optional: Flask-Mail suppression switch (tests/CI typically set true)
# MAIL_SUPPRESS_SEND=false
# Optional: suppress recipient after permanent SMTP failure (seconds)
# EMAIL_SUPPRESSION_TTL_SECONDS=1209600
# Optional: Redis/cache key prefix for suppressed recipients
# EMAIL_SUPPRESSION_CACHE_PREFIX=digitva_email_suppressed:

# =============================================================================
# Optional: External Service URLs (override defaults if needed)
# =============================================================================

# Redis — password required (set REDIS_PASSWORD, URLs are built from it in docker-compose.yml)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
REDIS_PASSWORD=your-random-48-char-hex-secret-here
REDIS_URL=redis://:your-random-48-char-hex-secret-here@minerva_redis_service:6379/0
CELERY_BROKER_URL=redis://:your-random-48-char-hex-secret-here@minerva_redis_service:6379/0
CELERY_RESULT_BACKEND=redis://:your-random-48-char-hex-secret-here@minerva_redis_service:6379/0
